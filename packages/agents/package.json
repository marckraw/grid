{
  "name": "@mrck-labs/grid-agents",
  "version": "0.7.0",
  "description": "Agent orchestration primitives for Grid",
  "keywords": [
    "agents",
    "orchestration",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "zshy": {
    "exports": {
      ".": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "zshy",
    "dev": "zshy --watch",
    "lint": "biome check src",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "zshy": "^0.0.4"
  },
  "dependencies": {
    "@mrck-labs/grid-core": "workspace:*",
    "@mrck-labs/grid-tools": "workspace:*",
    "zod": "^3.22.4"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
