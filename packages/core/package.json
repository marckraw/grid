{
  "name": "@mrck-labs/grid-core",
  "version": "0.6.0",
  "description": "Core primitives for LLM orchestration and agentic workflows",
  "keywords": [
    "llm",
    "ai",
    "agents",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "zshy": {
    "exports": {
      ".": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "zshy",
    "dev": "zshy --watch",
    "lint": "biome check src",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "zshy": "^0.0.4"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.23",
    "ai": "^4.3.19",
    "openai": "^5.9.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "langfuse": "^3.38.4"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}