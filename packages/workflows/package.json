{
  "name": "@mrck-labs/grid-workflows",
  "version": "19.0.0",
  "description": "Workflow patterns for Grid LLM orchestration",
  "keywords": [
    "llm",
    "ai",
    "workflows",
    "agents",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "dts": true,
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "format": [
      "esm",
      "cjs"
    ],
    "outDir": "dist",
    "minify": false,
    "target": "es2020"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "test": "vitest"
  },
  "devDependencies": {
    "@mrck-labs/grid-core": "workspace:*",
    "@biomejs/biome": "^1.4.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "tsup": "^8.5.0"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@mrck-labs/grid-core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}