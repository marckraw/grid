{
  "name": "@mrck-labs/grid-core",
  "version": "0.35.0",
  "description": "Core primitives for LLM orchestration and agentic workflows",
  "keywords": [
    "llm",
    "ai",
    "agents",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "dts": true,
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "format": [
      "esm",
      "cjs"
    ],
    "outDir": "dist",
    "minify": false,
    "target": "es2020"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "tsup": "^8.5.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.9",
    "@ai-sdk/mcp": "^0.0.7",
    "@ai-sdk/openai": "^2.0.22",
    "@elevenlabs/elevenlabs-js": "^2.7.0",
    "@mendable/firecrawl-js": "^1.29.1",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "ai": "^5.0.35",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "openai": "^5.9.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "langfuse": "^3.38.4"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}