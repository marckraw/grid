# Grid Terminal Agent Configuration
# Copy this file to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Configuration (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ElevenLabs API Configuration (optional - for voice features)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Grid API Configuration
GRID_API_KEY=your-grid-api-key-here
GRID_BASE_URL=https://api.grid.dev
GRID_TIMEOUT=30000
GRID_RETRIES=3

# Agent Configuration
DEFAULT_MODEL=gpt-4
MAX_ITERATIONS=10

# Development
NODE_ENV=development
LOG_LEVEL=info

# MCP (Model Context Protocol) Server Configuration (optional)
# Uncomment and configure to enable MCP tools in agent conversation
# Example: Filesystem MCP server
# MCP_SERVER_COMMAND=npx
# MCP_SERVER_ARGS=@modelcontextprotocol/server-filesystem /tmp

# Example: Weather MCP server
# MCP_SERVER_COMMAND=node
# MCP_SERVER_ARGS=/path/to/weather-mcp-server.js

# Example: Database MCP server
# MCP_SERVER_COMMAND=python
# MCP_SERVER_ARGS=/path/to/database-mcp-server.py

# Linear MCP Server Configuration
# Get your API key from Linear: Settings → API → Create new API key
LINEAR_API_KEY=your-linear-api-key-here

# Langfuse Observability Configuration (optional)
# Get your keys from https://cloud.langfuse.com or your self-hosted instance
# These enable tracing of LLM calls, tool executions, and conversation flows
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
# Optional: Set if using self-hosted Langfuse (default: https://cloud.langfuse.com)
# LANGFUSE_BASEURL=https://your-langfuse-instance.com