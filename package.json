{
  "name": "grid",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript library for LLM orchestration and agentic workflows",
  "keywords": [
    "llm",
    "ai",
    "agents",
    "orchestration",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ci": "turbo run test -- --run",
    "test:watch": "turbo run test -- --watch",
    "test:coverage": "turbo run test -- --coverage",
    "lint": "turbo run lint",
    "docs": "pnpm --filter docs start",
    "terminal-agent": "pnpm run build && pnpm --filter terminal-agent dev",
    "nextjs-test": "pnpm --filter nextjs-test dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "release:status": "changeset status",
    "release:dry-run": "changeset status --verbose"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.10.0",
    "knip": "^5.63.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3",
    "zshy": "^0.3.5"
  },
  "packageManager": "pnpm@8.15.1",
  "pnpm": {
    "overrides": {
      "@changesets/cli>globby": "11.1.0",
      "zshy>globby": "11.1.0"
    }
  }
}